# Optional login access codes for the static Vercel build.
# If omitted, the app defaults to admin2026 and staff2026.
VITE_ADMIN_ACCESS_CODE=admin2026
VITE_STAFF_ACCESS_CODE=staff2026

# Google integrations use Firebase Auth with Gmail/Sheets OAuth scopes.
# Configure firebase-applet-config.json with your Firebase web app details and add your Vercel domain to Firebase Auth authorized domains.
